---
import client from '../data/client.json';
---

<section class="py-20" style="background:var(--brand-surface)">
  <div class="max-w-4xl mx-auto px-6 text-center">
    <div class="text-xs uppercase tracking-[0.3em] font-semibold mb-3" style="color:var(--brand-primary-light)">
      Where We Work
    </div>
    <h2 class="text-3xl md:text-4xl font-bold mb-8" style="color:#1A1A1A">
      Proudly Serving {client.business.serviceArea[0]}<br />& Surrounding Areas
    </h2>
    <div class="flex flex-wrap justify-center gap-3">
      {client.business.serviceArea.map(area => (
        <span class="px-5 py-2.5 rounded-full bg-white border text-sm font-semibold"
          style="border-color:color-mix(in srgb, var(--brand-primary) 15%, transparent);color:var(--brand-primary)">
          📍 {area}
        </span>
      ))}
    </div>
  </div>
</section>
