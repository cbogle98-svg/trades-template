---
import client from '../data/client.json';

const subjectOptions = client.services.items.map(s => s.title);
---

<form
  id="contact-form"
  action="https://api.web3forms.com/submit"
  method="POST"
  class="flex flex-col gap-3"
>
  <!-- Web3Forms required fields -->
  <input type="hidden" name="access_key" value={client.contact.accessKey} />
  <input type="hidden" name="subject" value={`${client.contact.subjectPrefix} — ${client.business.name}`} />
  <input type="hidden" name="from_name" value={client.business.name} />
  <!-- Honeypot anti-spam field; bots fill this, humans don't see it -->
  <input type="checkbox" name="botcheck" class="hidden" style="display:none" tabindex="-1" autocomplete="off" />

  <input
    type="text"
    name="name"
    placeholder="Your Name"
    required
    class="px-4 py-3.5 rounded-lg border bg-white/5 text-white placeholder-white/40 outline-none transition focus:bg-white/10"
    style="border-color:rgba(255,255,255,0.12);font-family:var(--font-body)"
  />
  <input
    type="email"
    name="email"
    placeholder="Email Address"
    required
    class="px-4 py-3.5 rounded-lg border bg-white/5 text-white placeholder-white/40 outline-none transition focus:bg-white/10"
    style="border-color:rgba(255,255,255,0.12);font-family:var(--font-body)"
  />
  <input
    type="tel"
    name="phone"
    placeholder="Phone Number"
    required
    class="px-4 py-3.5 rounded-lg border bg-white/5 text-white placeholder-white/40 outline-none transition focus:bg-white/10"
    style="border-color:rgba(255,255,255,0.12);font-family:var(--font-body)"
  />
  <select
    name="service_interest"
    required
    class="px-4 py-3.5 rounded-lg border bg-white/5 text-white outline-none transition focus:bg-white/10"
    style="border-color:rgba(255,255,255,0.12);font-family:var(--font-body)"
  >
    <option value="" style="color:#1A1A1A">What do you need help with?</option>
    {subjectOptions.map(opt => (
      <option value={opt} style="color:#1A1A1A">{opt}</option>
    ))}
    <option value="Other" style="color:#1A1A1A">Something else</option>
  </select>
  <textarea
    name="message"
    rows="4"
    placeholder="Tell us about your project..."
    required
    class="px-4 py-3.5 rounded-lg border bg-white/5 text-white placeholder-white/40 outline-none transition focus:bg-white/10 resize-y min-h-[100px]"
    style="border-color:rgba(255,255,255,0.12);font-family:var(--font-body)"
  ></textarea>
  <button
    type="submit"
    id="contact-submit"
    class="mt-2 px-6 py-4 rounded-lg font-bold text-base transition hover:-translate-y-0.5 disabled:opacity-50 disabled:cursor-not-allowed"
    style="background:var(--brand-accent);color:#1A1A1A;font-family:var(--font-body)"
  >
    Send Message →
  </button>
  <div
    id="contact-status"
    class="hidden text-sm mt-2 px-4 py-3 rounded-lg"
    role="status"
    aria-live="polite"
  ></div>
</form>

<script define:vars={{ successMsg: client.contact.successMessage, errorMsg: client.contact.errorMessage }}>
  const form = document.getElementById('contact-form');
  const status = document.getElementById('contact-status');
  const button = document.getElementById('contact-submit');

  if (form) {
    form.addEventListener('submit', async (event) => {
      event.preventDefault();
      const formData = new FormData(form);
      const originalText = button.textContent;
      button.disabled = true;
      button.textContent = 'Sending...';
      status.classList.add('hidden');

      try {
        const res = await fetch('https://api.web3forms.com/submit', {
          method: 'POST',
          body: formData,
        });
        const json = await res.json();
        if (res.ok && json.success) {
          status.textContent = successMsg;
          status.className = 'text-sm mt-2 px-4 py-3 rounded-lg bg-green-500/10 text-green-300 border border-green-500/30';
          form.reset();
        } else {
          status.textContent = (json && json.message) || errorMsg;
          status.className = 'text-sm mt-2 px-4 py-3 rounded-lg bg-red-500/10 text-red-300 border border-red-500/30';
        }
      } catch (err) {
        status.textContent = errorMsg;
        status.className = 'text-sm mt-2 px-4 py-3 rounded-lg bg-red-500/10 text-red-300 border border-red-500/30';
      } finally {
        button.disabled = false;
        button.textContent = originalText;
      }
    });
  }
</script>
