---
import client from '../data/client.json';
---

<section class="py-24">
  <div class="max-w-6xl mx-auto px-6">
    <div class="text-center max-w-2xl mx-auto mb-16">
      <div class="text-xs uppercase tracking-[0.3em] font-semibold mb-3" style="color:var(--brand-primary-light)">
        {client.testimonials.eyebrow}
      </div>
      <h2 class="text-4xl md:text-5xl font-bold mb-4" style="color:#1A1A1A">
        {client.testimonials.headline}
      </h2>
    </div>
    <div class="grid md:grid-cols-3 gap-6">
      {client.testimonials.items.map(t => (
        <div class="border border-black/5 rounded-2xl p-8" style="background:var(--brand-surface)">
          <div class="text-xl mb-4 tracking-widest" style="color:var(--brand-accent)">★★★★★</div>
          <p class="text-base italic leading-relaxed mb-6" style="color:var(--brand-text)">
            "{t.quote}"
          </p>
          <div class="text-sm font-semibold" style="color:#1A1A1A">{t.author}</div>
          <div class="text-xs" style="color:var(--brand-text-light)">{t.location}</div>
        </div>
      ))}
    </div>
  </div>
</section>
