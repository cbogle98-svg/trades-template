---
import client from '../data/client.json';
import ContactForm from './ContactForm.astro';
const phoneDigits = client.business.phone.replace(/\D/g, '');
---

<section id="contact" class="py-24" style="background:var(--brand-primary-dark)">
  <div class="max-w-6xl mx-auto px-6">
    <div class="grid md:grid-cols-2 gap-16 items-start">
      <div>
        <div class="text-xs uppercase tracking-[0.3em] font-semibold mb-3" style="color:var(--brand-primary-light)">
          {client.cta.eyebrow}
        </div>
        <h2 class="text-4xl md:text-5xl font-bold mb-6 text-white leading-tight">
          {client.cta.headline}
        </h2>
        <p class="text-lg leading-relaxed text-white/60 mb-10">
          {client.cta.subtext}
        </p>

        <div class="space-y-6">
          <a href={`tel:${phoneDigits}`} class="block transition hover:opacity-80">
            <div class="text-xs uppercase tracking-widest text-white/40 mb-1">Call us</div>
            <div class="text-3xl md:text-4xl font-bold" style="color:var(--brand-accent);font-family:var(--font-heading)">
              {client.business.phone}
            </div>
          </a>

          <a href={`mailto:${client.business.email}`} class="block transition hover:opacity-80">
            <div class="text-xs uppercase tracking-widest text-white/40 mb-1">Email</div>
            <div class="text-base text-white/80">{client.business.email}</div>
          </a>

          <div>
            <div class="text-xs uppercase tracking-widest text-white/40 mb-1">Visit</div>
            <div class="text-base text-white/80">
              {client.business.address.street}<br />
              {client.business.address.city}, {client.business.address.state} {client.business.address.zip}
            </div>
          </div>

          <div>
            <div class="text-xs uppercase tracking-widest text-white/40 mb-1">Hours</div>
            <div class="text-base text-white/80">
              {client.business.hours.weekdays} (Weekdays)<br />
              Saturday: {client.business.hours.saturday}<br />
              Sunday: {client.business.hours.sunday}
            </div>
          </div>
        </div>
      </div>

      <div class="bg-white/5 border border-white/10 rounded-2xl p-8 md:p-10">
        <h3 class="text-xl font-bold text-white mb-2" style="font-family:var(--font-heading)">
          Send Us a Message
        </h3>
        <p class="text-sm text-white/50 mb-6">
          Tell us about your project and we'll get back to you within 24 hours.
        </p>
        <ContactForm />
      </div>
    </div>
  </div>
</section>
