---
import client from '../data/client.json';
import HoursBadge from './HoursBadge.astro';

interface Props {
  // For Pro tier multi-page sites, the slug of the current page so nav
  // can highlight it. Undefined on the home page (and on all Starter/
  // Business single-page sites).
  currentPage?: string;
}
const { currentPage } = Astro.props;

const phoneDigits = client.business.phone.replace(/\D/g, '');
const tier = ((client as any).tier ?? 'business') as 'starter' | 'business' | 'pro';
const pages = (client as any).pages ?? [];

// Pro tier with declared pages → real page links. Otherwise → existing
// in-page anchor links (preserves Starter/Business behavior unchanged).
const navItems: { href: string; label: string; slug?: string }[] =
  tier === 'pro' && pages.length > 0
    ? pages.map((p: any) => ({
        href: `/${p.slug}`,
        label: p.navLabel ?? p.title,
        slug: p.slug
      }))
    : [
        { href: '/#services', label: 'Services' },
        { href: '/#about', label: 'About' },
        { href: '/#gallery', label: 'Our Work' },
        { href: '/#contact', label: 'Contact' }
      ];
---

<header class="sticky top-0 z-50 bg-[var(--brand-bg)]/95 backdrop-blur-md border-b border-black/5">
  <div class="max-w-6xl mx-auto px-6 py-4 flex items-center justify-between">
    <a href="/" class="block">
      <span class="block text-2xl font-bold leading-none" style="font-family:var(--font-heading);color:var(--brand-primary-dark)">
        {client.business.name}
      </span>
      <span class="block text-[10px] tracking-[0.2em] uppercase mt-1" style="color:var(--brand-text-light)">
        {client.business.industry}
      </span>
    </a>
    <nav class="hidden md:flex items-center gap-8 text-sm font-medium" style="color:var(--brand-text)">
      {navItems.map(item => (
        <a
          href={item.href}
          class={`hover:opacity-70 transition ${item.slug && item.slug === currentPage ? 'opacity-100 font-bold' : ''}`}
          style={item.slug && item.slug === currentPage ? `color:var(--brand-primary)` : undefined}
        >
          {item.label}
        </a>
      ))}
    </nav>
    <div class="flex items-center gap-3">
      <HoursBadge />
      <a
        href={`tel:${phoneDigits}`}
        class="inline-flex items-center gap-2 px-5 py-2.5 rounded-md text-white font-semibold text-sm transition hover:-translate-y-0.5 hover:shadow-lg"
        style="background:var(--brand-primary)"
      >
        📞 <span class="hidden sm:inline">{client.business.phone}</span><span class="sm:hidden">Call</span>
      </a>
    </div>
  </div>
</header>
