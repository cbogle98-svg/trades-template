---
import '../styles/global.css';
import client from '../data/client.json';

interface Props {
  title?: string;
  description?: string;
}

const { title, description } = Astro.props;
const pageTitle = title ?? `${client.business.name} — ${client.business.tagline}`;
const pageDesc = description ?? `${client.business.industry} serving ${client.business.address.city}, ${client.business.address.state}.`;

const fontHeadingUrl = client.brand.fontHeading.replace(/ /g, '+');
const fontBodyUrl = client.brand.fontBody.replace(/ /g, '+');

const siteUrl = (client as any).siteUrl ?? Astro.url.origin;
const isDemo = (client as any).isDemo === true;

// Detect restaurant-class businesses via explicit businessType field OR
// auto-detect from industry keywords. Restaurants get Restaurant schema
// (which extends LocalBusiness with servesCuisine + hasMenu fields) so
// menu items can appear in Google's rich results for food searches.
const business = client.business as any;
const RESTAURANT_INDUSTRY_RE = /restaurant|bbq|smokehouse|cafe|caf[eé]|diner|pizz|grill|deli|bistro|bakery/i;
const businessType: string = business.businessType
  ?? (RESTAURANT_INDUSTRY_RE.test(business.industry ?? '') ? 'Restaurant' : 'LocalBusiness');

// For multi-page Pro sites with a declared menu page, point hasMenu at
// the menu page URL. For single-page sites, point at the Services anchor.
const isProMultipage = client.tier === 'pro' && Array.isArray(client.pages) && client.pages.length > 0;
const menuPage = isProMultipage ? client.pages.find((p: any) => p.slug === 'menu' || p.slug === 'services') : null;
const menuPath = menuPage ? `/${menuPage.slug}` : '/#services';

const baseSchema: Record<string, any> = {
  "@context": "https://schema.org",
  "@type": businessType,
  "name": client.business.name,
  "description": pageDesc,
  "url": siteUrl,
  "telephone": client.business.phone,
  "email": client.business.email,
  "address": {
    "@type": "PostalAddress",
    "streetAddress": client.business.address.street,
    "addressLocality": client.business.address.city,
    "addressRegion": client.business.address.state,
    "postalCode": client.business.address.zip,
    "addressCountry": "US"
  },
  "areaServed": client.business.serviceArea,
  "openingHours": [
    `Mo-Fr ${client.business.hours.weekdays.replace(/[–—]/g, '-').replace(/\s/g, '')}`
  ],
  ...(client.business.yearFounded && { "foundingDate": String(client.business.yearFounded) }),
  ...(client.business.social?.facebook && { "sameAs": [client.business.social.facebook, client.business.social.google].filter(Boolean) })
};

// Restaurant-specific extensions: servesCuisine + hasMenu (Menu object
// with each services item as a MenuItem). Lets Google surface menu items
// directly in search results when someone searches for the food.
if (businessType === 'Restaurant') {
  if (business.cuisine) baseSchema.servesCuisine = business.cuisine;
  const items = (client.services?.items ?? []) as any[];
  if (items.length > 0) {
    baseSchema.hasMenu = {
      "@type": "Menu",
      "name": client.services?.headline ?? "Menu",
      "url": `${siteUrl}${menuPath}`,
      "hasMenuSection": [
        {
          "@type": "MenuSection",
          "name": client.services?.headline ?? "Menu",
          "hasMenuItem": items.map((item: any) => {
            const node: Record<string, any> = {
              "@type": "MenuItem",
              "name": item.title,
            };
            if (item.description) node.description = item.description;
            // Parse price like "$16", "$15.50", "Ask" — only emit Offer
            // if we can extract a real numeric price.
            if (item.price) {
              const priceNum = String(item.price).replace(/[^\d.]/g, '');
              if (priceNum && !isNaN(parseFloat(priceNum))) {
                node.offers = {
                  "@type": "Offer",
                  "price": priceNum,
                  "priceCurrency": "USD"
                };
              }
            }
            return node;
          })
        }
      ]
    };
  }
}

const businessSchema = baseSchema;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>{pageTitle}</title>
    <meta name="description" content={pageDesc} />
    {isDemo && <meta name="robots" content="noindex,nofollow" />}
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={pageDesc} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={siteUrl} />
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={pageDesc} />
    {!isDemo && <script type="application/ld+json" set:html={JSON.stringify(businessSchema)} />}
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href={`https://fonts.googleapis.com/css2?family=${fontHeadingUrl}:wght@600;700;800&family=${fontBodyUrl}:wght@300;400;500;600;700&display=swap`}
      rel="stylesheet"
    />
    <style is:global define:vars={{
      brandPrimary: client.brand.primary,
      brandPrimaryDark: client.brand.primaryDark,
      brandPrimaryLight: client.brand.primaryLight,
      brandAccent: client.brand.accent,
      brandBg: client.brand.background,
      brandSurface: client.brand.surface,
      brandText: client.brand.text,
      brandTextLight: client.brand.textLight,
      fontHeading: `'${client.brand.fontHeading}', serif`,
      fontBody: `'${client.brand.fontBody}', sans-serif`
    }}>
      :root {
        --brand-primary: var(--brandPrimary);
        --brand-primary-dark: var(--brandPrimaryDark);
        --brand-primary-light: var(--brandPrimaryLight);
        --brand-accent: var(--brandAccent);
        --brand-bg: var(--brandBg);
        --brand-surface: var(--brandSurface);
        --brand-text: var(--brandText);
        --brand-text-light: var(--brandTextLight);
        --font-heading: var(--fontHeading);
        --font-body: var(--fontBody);
      }
      body {
        background: var(--brand-bg);
        color: var(--brand-text);
        font-family: var(--font-body);
      }
      h1, h2, h3, h4, h5, h6 {
        font-family: var(--font-heading);
      }
    </style>
  </head>
  <body class="antialiased">
    <slot />
  </body>
</html>
